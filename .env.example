# ===== База данных (PostgreSQL через Docker) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockdb
DB_USER=stock
DB_PASSWORD=stockpass
DATABASE_URL=postgresql+psycopg://stock:stockpass@localhost:5432/stockdb

# ===== Загрузка данных =====
SYMBOLS=AAPL,TSLA,MSFT,GLD,^GSPC,^IXIC,^DJI,^RUT,^VIX,^IRX,^TNX
START_DATE=2015-01-01
SOURCE=yfinance
LOOKBACK_DAYS=7

# ===== Обучение =====
TRAIN_START_DATE=2015-01-01
HORIZON_DAYS=5

# ===== Telegram-бот (получить токен у @BotFather) =====
TELEGRAM_BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE

# ===== Бэктест =====
BACKTEST_START_DATE=2020-01-01
BACKTEST_FEE_BPS=0
BACKTEST_PROB_THRESHOLD=0.55
BACKTEST_INITIAL_CAPITAL=10000

# ===== Модели =====
MODELS_DIR=artifacts/models
